# EditorConfig helps maintain consistent coding styles across editors and IDEs.
# See: https://editorconfig.org/

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.{js,jsx,ts,tsx,json}]
quote_type = single
max_line_length = 100

[*.{yml,yaml}]
indent_size = 2
insert_final_newline = true

[*.md]
trim_trailing_whitespace = false
max_line_length = off

[*.{env,ini,conf}]
indent_style = space
indent_size = 2

[package.json]
indent_size = 2

[*.{html,css,scss}]
indent_size = 2

[*.{gitattributes,gitignore}]
insert_final_newline = true